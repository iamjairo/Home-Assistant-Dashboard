{
  "appId": "dev.tunet.dashboard",
  "appName": "Tunet Dashboard",
  "webDir": "dist",
  "bundledWebRuntime": false,
  "server": {
    "hostname": "localhost",
    "androidScheme": "https"
  },
  "ios": {
    "scheme": "tunet",
    "contentInset": "always",
    "backgroundColor": "#0a0a0f",
    "preferredContentMode": "mobile"
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 0,
      "backgroundColor": "#0a0a0f",
      "showSpinner": false
    },
    "StatusBar": {
      "style": "Dark",
      "backgroundColor": "#0a0a0f"
    }
  }
}
